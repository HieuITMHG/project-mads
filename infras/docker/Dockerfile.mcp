FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PATH="/opt/venv/bin:$PATH"

WORKDIR /app/backend

RUN groupadd -g 1410 appgroup && \
    useradd -u 1410 -g appgroup -m -s /bin/bash appuser

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

RUN mkdir -p /opt/venv && chown -R appuser:appgroup /opt/venv

USER appuser

COPY --chown=appuser:appgroup backend/pyproject.toml backend/uv.lock ./
RUN uv sync --extra mcp-server --no-dev --no-install-project

COPY --chown=appuser:appgroup backend/core/config.py ./core/config.py
COPY --chown=appuser:appgroup backend/mcp_server ./mcp_server

CMD ["uv", "run", "python", "-m", "mcp_server.main"]