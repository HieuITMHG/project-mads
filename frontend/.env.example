# ==============================================================
# MADS Frontend – Environment Variables Template
# ==============================================================
# Sao chép file này thành .env.development hoặc .env.production
# rồi chỉnh giá trị cho phù hợp với môi trường của bạn.
#
# Vite chỉ đọc các biến có prefix VITE_
# ==============================================================

# URL gốc của backend API (không có dấu / ở cuối)
# Dev:  http://localhost:8000
# Prod: https://suvitech.io.vn
VITE_API_URL=http://localhost:8000
